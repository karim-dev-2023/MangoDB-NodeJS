<%- include('layouts/header') %> <%- include('layouts/navbar') %>
<!-- Page Header-->
<header
  class="masthead"
  style="<%= blogPost.image ? `background-image: url(/images/${blogPost.image})` : '' %>"
>
  <div class="overlay"></div>

  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-10 mx-auto">
        <div class="post-heading text-white">
          <h1><%= blogPost.title %></h1>

          <h2 class="subheading"><%= blogPost.body %></h2>

          <span class="meta">
            Posted by
            <a href="#">Start Bootstrap</a>
            on August 24, 2019
          </span>
        </div>
      </div>
    </div>
  </div>
</header>
<!-- Post Content-->
<article class="mb-4">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-10 mx-auto"><%= blogPost.body %></div> 
    </div>
  </div>
</article>
<%- include('layouts/footer') %>

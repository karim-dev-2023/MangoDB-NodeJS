<%- include('layouts/header') %> <%- include('layouts/navbar') %>
<!-- Page Header-->
<header
  class="masthead"
  style="<%= blogPost.image ? `background-image: url(/images/${blogPost.image})` : '' %>"
>
  <div class="overlay"></div>

  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-10 mx-auto">
        <div class="post-heading text-white">
          <h1><%= blogPost.title %></h1>

          <h2 class="subheading"><%= blogPost.body %></h2>

          <% if (blogPost.userid) { %>
            <span class="meta">
              Posted by
              <a href="#"><%= blogPost.userid.username %></a>
              on <%= blogPost.createdAt.toDateString() %>
            </span>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</header>
<!-- Post Content-->
<article class="mb-4">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-10 mx-auto"><%= blogPost.body %></div> 
    </div>
  </div>
</article>
<%- include('layouts/footer') %>
